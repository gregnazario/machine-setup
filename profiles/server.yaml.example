name: server
description: Server profile - minimal + monitoring + networking tools
extends: minimal

packages:
  monitoring:
    - btop
    - htop
  networking:
    - curl
    - wget
  system:
    - tmux

dotfiles:
  source: profiles/server/
  links:
    - src: .config/nushell/
      dest: ~/.config/nushell/
    - src: .config/nvim/
      dest: ~/.config/nvim/
    - src: .tmux.conf
      dest: ~/.tmux.conf

services:
  - sshd
  - cronie

setup_scripts:
  - scripts/setup-ssh-agent.sh
