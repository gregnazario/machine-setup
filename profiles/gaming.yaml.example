name: gaming
description: Gaming-focused setup with Wine, controllers, and gaming tools
extends: full

packages:
  gaming:
    - wine
    - lutris
    - steam
    - mangohud
  gaming_utils:
    - gamecontrollerdb

dotfiles:
  source: profiles/gaming/
  links:
    - src: .config/lutris/
      dest: ~/.config/lutris/
    - src: .steam/
      dest: ~/.steam/

services:
  - steam-client

setup_scripts:
  - scripts/setup-wine.sh
  - scripts/setup-gaming-permissions.sh
