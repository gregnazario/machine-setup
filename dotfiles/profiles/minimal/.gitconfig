# Git Configuration (Minimal)
# Location: ~/.gitconfig

[user]
    name = Your Name
    email = your.email@example.com
    signingkey = YOUR_GPG_KEY_ID

[core]
    editor = nvim
    autocrlf = input
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[commit]
    gpgsign = true

[push]
    default = simple

[pull]
    rebase = false

[init]
    defaultBranch = main

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    unstage = reset HEAD --
    last = log -1 HEAD
    visual = !gitk
    lg = log --oneline --decorate --all --graph
