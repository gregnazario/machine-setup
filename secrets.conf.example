# secrets.conf — maps password-manager entries to local destinations.
#
# Copy this file to secrets.conf and uncomment / edit the entries you need.
# Run:  ./scripts/secrets/secrets-manager.sh pull   to fetch secrets
#        ./scripts/secrets/secrets-manager.sh push   to push local values back
#        ./scripts/secrets/secrets-manager.sh list   to show all mappings
#        ./scripts/secrets/secrets-manager.sh status to check what exists
#
# ── Provider ────────────────────────────────────────────────────────────────
# Specify which password-manager backend to use.
# Supported: 1password, bitwarden, keeper, apple-keychain,
#            linux-keyring, windows-credential
# If omitted, the first available provider is auto-detected.

[provider]
# name = 1password
# vault = Personal
# cache_backend = none

# ── Secret mappings ─────────────────────────────────────────────────────────
# Each [secret.<name>] section maps one provider entry to a local destination.
#
# Common fields:
#   provider_key   — lookup key / item name in the password manager
#   dest           — destination type: ini | file | env
#
# For dest = ini:
#   dest_file      — path to the INI file (relative to repo root or absolute)
#   dest_section   — INI section name
#   dest_key       — INI key name
#
# For dest = file:
#   dest_file      — path to write the secret into
#   dest_mode      — file permission mode (default 0600)
#
# For dest = env:
#   dest_var       — environment variable name

# ── Example: INI destination ────────────────────────────────────────────────
# Write a Restic password into an INI config file.

# [secret.restic-password]
# provider_key = Restic Backup Password
# dest = ini
# dest_file = backup/restic-config.conf
# dest_section = restic
# dest_key = password

# ── Example: file destination ───────────────────────────────────────────────
# Write an SSH private key to a file with strict permissions.

# [secret.ssh-key]
# provider_key = SSH Private Key - Laptop
# dest = file
# dest_file = ~/.ssh/id_ed25519
# dest_mode = 0600

# ── Example: env destination ────────────────────────────────────────────────
# Export a GitHub token as an environment variable.

# [secret.github-token]
# provider_key = GitHub PAT
# dest = env
# dest_var = GITHUB_TOKEN
